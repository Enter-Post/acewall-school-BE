# ============================================
# AceWall Scholars Backend Environment Variables
# ============================================

# Server Configuration
PORT=5050
NODE_ENV=development
BACKEND_BASE_URL=http://localhost:5050
FRONTEND_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# Session Configuration (Required for SAML)
SESSION_SECRET=your_session_secret_change_in_production

# ============================================
# SAML 2.0 SSO Configuration
# ============================================

# Okta SAML Configuration
# Get these values from your Okta Admin Console:
# Applications > Your App > Sign On > View SAML setup instructions
SAML_OKTA_ENTRY_POINT=https://your-domain.okta.com/app/okta_yourapp/exk123456/sso/saml
SAML_OKTA_ISSUER=http://localhost:5050
SAML_OKTA_CERT=-----BEGIN CERTIFICATE-----
MIIDXTCCAkWgAwIBAgIJAKL0UG+mV8BEMA0GCSqGSIb3DQEBCwUAMEUxCzAJBgNV
# ... (paste your Okta certificate here)
-----END CERTIFICATE-----

# Azure AD SAML Configuration (Optional - for future use)
SAML_AZURE_ENTRY_POINT=https://login.microsoftonline.com/{tenant-id}/saml2
SAML_AZURE_ISSUER=your-app-identifier
SAML_AZURE_CERT=-----BEGIN CERTIFICATE-----
# ... (paste your Azure certificate here)
-----END CERTIFICATE-----

# SAML Signing (Optional - if you need signed requests)
SAML_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----
# ... (your private key for signing SAML requests)
-----END PRIVATE KEY-----

# ============================================
# OAuth & Third-Party Integrations
# ============================================

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Clever OAuth (if enabled)
CLEVER_CLIENT_ID=your_clever_client_id
CLEVER_CLIENT_SECRET=your_clever_client_secret
CLEVER_REDIRECT_URI=http://localhost:5050/api/auth/clever/callback

# ============================================
# Email Configuration
# ============================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
FROM_EMAIL=noreply@acewallscholars.com
FROM_NAME=AceWall Scholars

# ============================================
# Cloud Storage & File Uploads
# ============================================

CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ============================================
# Other Services
# ============================================

# Stripe (Payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Zoom API
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret

# OpenAI / Gemini API
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=AIzaSy...

# Twilio (SMS)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1234567890

# ============================================
# Important SAML Setup Instructions
# ============================================

# 1. Okta Configuration:
#    - Single Sign-On URL: http://localhost:5050/api/auth/saml/callback/okta
#    - Audience URI: http://localhost:5050 (must match SAML_OKTA_ISSUER)
#    - Name ID Format: EmailAddress
#    - Attribute Statements:
#      * email -> user.email
#      * firstName -> user.firstName
#      * lastName -> user.lastName

# 2. For Production:
#    - Update BACKEND_BASE_URL and FRONTEND_URL
#    - Use HTTPS URLs
#    - Change SESSION_SECRET to a strong random string
#    - Update SAML_OKTA_ISSUER to match your production domain

# 3. Certificate Format:
#    - Paste the entire certificate including BEGIN/END markers
#    - Replace newlines with actual line breaks, not \n
