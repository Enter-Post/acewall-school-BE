# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/district-qa

# FERPA Compliance - Field-Level Encryption
# Must be a secure 32-character string for encrypting sensitive student data at rest
DB_ENCRYPTION_KEY=your-32-character-encryption-key-here

# FERPA Compliance - TLS Certificates (Optional but recommended for production)
# Path to CA certificate for MongoDB TLS connection
MONGODB_CA_CERT=/path/to/ca-cert.pem
# Path to client certificate for MongoDB TLS connection
MONGODB_CLIENT_CERT=/path/to/client-cert.pem

# Server Configuration
PORT=5000
NODE_ENV=development

# JWT Secret
JWT_SECRET=your-jwt-secret-here

# Google OAuth (if using Google auth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/auth/google/callback

# Clever OAuth (if using Clever auth)
CLEVER_CLIENT_ID=your-clever-client-id
CLEVER_CLIENT_SECRET=your-clever-client-secret
CLEVER_REDIRECT_URI=http://localhost:5000/auth/clever/callback

# SAML Configuration (if using SAML auth)
SAML_ENTRY_POINT=https://your-saml-idp-entry-point
SAML_ISSUER=https://your-app-issuer
SAML_CALLBACK_URL=http://localhost:5000/auth/saml/callback
SAML_CERT=path-to-saml-cert

# Cloudinary (for file uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Google Drive API (if using Google Drive integration)
GOOGLE_DRIVE_CLIENT_ID=your-google-drive-client-id
GOOGLE_DRIVE_CLIENT_SECRET=your-google-drive-client-secret
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:5000/auth/google-drive/callback
