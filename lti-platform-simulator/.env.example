# LTI Platform Simulator Configuration
# Copy this file to .env and update the values for your environment

# Platform Configuration
PLATFORM_ISSUER=http://localhost:4000
PLATFORM_CLIENT_ID=lti-tool-client-id
PLATFORM_DEPLOYMENT_ID=test-deployment-1
PLATFORM_PORT=4000

# LMS Configuration
LMS_URL=http://localhost:5050

# For Production with ngrok:
# PLATFORM_ISSUER=https://your-ngrok-url.ngrok-free.dev
# LMS_URL=https://your-lms-ngrok-url.ngrok-free.dev

# For Production with custom domain:
# PLATFORM_ISSUER=https://your-platform-domain.com
# LMS_URL=https://acewallscholarslearningonline.com
